+def mock_calculate_tnb_cost(kwh: float) -> float:
+    """Simulate db.calculate_tnb_cost()."""
+    tiers = [(200, 0.218), (100, 0.334), (300, 0.516), (float("inf"), 0.546)]
+    cost, remaining = 0.0, kwh
+    for limit, rate in tiers:
+        if remaining <= 0:
+            break
+        usage = min(remaining, limit)
+        cost += usage * rate
+        remaining -= usage
+    return round(cost, 4)
